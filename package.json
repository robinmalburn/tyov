{
  "name": "tyov",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "serve": "vite preview",
    "test:unit": "vitest",
    "lint": "prettier --check \"**/*.{js,ts,vue,mjs}\"",
    "lint:fix": "prettier --write \"**/*.{js,ts,vue,mjs}\"",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "pinia": "^3.0.4",
    "tailwindcss": "^4.3.2",
    "vite": "^8.1.0",
    "vue": "^3.5.39"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@vue/test-utils": "^2.4.11",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.5"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ],
  "engines": {
    "runtime": {
      "name": "node",
      "version": "^24.18.0",
      "onFail": "download"
    }
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24.16.0",
      "onFail": "download"
    },
    "packageManager": {
      "name": "pnpm",
      "version": "11.9.0",
      "onFail": "warn"
    }
  },
  "license": "MIT"
}
